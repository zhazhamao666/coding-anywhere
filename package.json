{
  "name": "feishu-codex-bridge",
  "version": "1.0.0",
  "description": "Dedicated Feishu to Codex bridge with native Codex CLI execution",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node scripts/dev.mjs",
    "doctor": "tsx src/doctor-cli.ts",
    "init:config": "tsx src/init-config.ts",
    "start": "node scripts/start.mjs",
    "stop": "node scripts/stop.mjs",
    "test": "vitest run",
    "test:bridge:codex": "vitest run tests/bridge-real-codex.test.ts",
    "test:codex:real": "vitest run tests/codex-real-smoke.test.ts",
    "test:codex:resume": "vitest run tests/codex-real-resume.test.ts",
    "test:feishu:auth": "tsx src/feishu-live-auth-cli.ts",
    "test:feishu:live": "node scripts/feishu-live.mjs dm",
    "test:feishu:live:dm": "node scripts/feishu-live.mjs dm",
    "test:feishu:live:dm:ui": "node scripts/feishu-live.mjs dm all",
    "test:feishu:live:group": "node scripts/feishu-live.mjs group",
    "test:feishu:live:group:ui": "node scripts/feishu-live.mjs group all",
    "test:feishu:live:topic": "node scripts/feishu-live.mjs topic all",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "better-sqlite3": "^12.4.1",
    "execa": "^9.6.0",
    "fastify": "^5.6.1",
    "pino": "^10.1.0",
    "prom-client": "^15.1.3",
    "toml": "^3.0.0",
    "ws": "^8.18.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
